	/// Soma o valor dos itens com nota fiscal faturada, filtrando por mês da data_faturamento e por filial.
	measure 'Faturamento Atacado' =
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR FiliaisSelecionadas = VALUES(protheus_filiais[Filial])
			VAR ResultadoSemData =
			    CALCULATE(
			        SUM(protheus_itensPedidosVendas[preco_total]),
			        NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			        TRIM(protheus_itensPedidosVendas[nota_fiscal]) <> "",
			        NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento])),
			        KEEPFILTERS(TREATAS(FiliaisSelecionadas, protheus_itensPedidosVendas[filial]))
			    )
			VAR ResultadoComData =
			    CALCULATE(
			        SUM(protheus_itensPedidosVendas[preco_total]),
			        NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			        TRIM(protheus_itensPedidosVendas[nota_fiscal]) <> "",
			        NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento])),
			        KEEPFILTERS(
			            FILTER(
			                protheus_itensPedidosVendas,
			                DATEVALUE(protheus_itensPedidosVendas[data_faturamento]) IN VALUES(calendario[Date])
			            )
			        ),
			        KEEPFILTERS(TREATAS(FiliaisSelecionadas, protheus_itensPedidosVendas[filial]))
			    )
			RETURN
			COALESCE(IF(TemFiltroData, ResultadoComData, ResultadoSemData), 0)
		formatString: R$ #,##0.00
		displayFolder: Atacado
		lineageTag: 92acf82e-4c7e-4250-8e11-c40f1622ed20

	/// Conta pedidos faturados distintos com base em nota fiscal preenchida e data_faturamento, respeitando calendário e filial.
	measure 'Pedidos Faturados' =
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR FiliaisSelecionadas = VALUES(protheus_filiais[Filial])
			VAR ResultadoSemData =
			    CALCULATE(
			        DISTINCTCOUNT(protheus_itensPedidosVendas[numero_pedido]),
			        NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			        TRIM(protheus_itensPedidosVendas[nota_fiscal]) <> "",
			        NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento])),
			        KEEPFILTERS(TREATAS(FiliaisSelecionadas, protheus_itensPedidosVendas[filial]))
			    )
			VAR ResultadoComData =
			    CALCULATE(
			        DISTINCTCOUNT(protheus_itensPedidosVendas[numero_pedido]),
			        NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			        TRIM(protheus_itensPedidosVendas[nota_fiscal]) <> "",
			        NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento])),
			        KEEPFILTERS(
			            FILTER(
			                protheus_itensPedidosVendas,
			                DATEVALUE(protheus_itensPedidosVendas[data_faturamento]) IN VALUES(calendario[Date])
			            )
			        ),
			        KEEPFILTERS(TREATAS(FiliaisSelecionadas, protheus_itensPedidosVendas[filial]))
			    )
			RETURN
			COALESCE(IF(TemFiltroData, ResultadoComData, ResultadoSemData), 0)
		formatString: #,##0
		displayFolder: Atacado
		lineageTag: 80926c25-25c6-4d4b-825a-786ed83442ec

	/// Quantidade total de pedidos em aberto (sem nota fiscal), ignorando filtro de calendário e respeitando filtro de filial.
	measure 'Pedidos em Aberto' =
			VAR FiliaisSelecionadas = VALUES(protheus_filiais[Filial])
			VAR Resultado =
			    CALCULATE(
			        DISTINCTCOUNT(protheus_itensPedidosVendas[numero_pedido]),
			        ISBLANK(protheus_itensPedidosVendas[nota_fiscal])
			            || TRIM(protheus_itensPedidosVendas[nota_fiscal]) = "",
			        REMOVEFILTERS(calendario),
			        KEEPFILTERS(TREATAS(FiliaisSelecionadas, protheus_itensPedidosVendas[filial]))
			    )
			RETURN
			COALESCE(Resultado, 0)
		formatString: #,##0
		displayFolder: Atacado
		lineageTag: 4af744e0-cdfd-41f3-916a-79e4504263da

	/// Ticket médio do atacado com base no faturamento dos itens e na quantidade de pedidos faturados corrigida.
	measure 'Ticket Medio Atacado' =
			DIVIDE(
			    [Faturamento Atacado],
			    [Pedidos Faturados],
			    0
			)
		formatString: R$ #,##0.00
		displayFolder: Atacado
		lineageTag: 3420992a-f53c-4206-8360-dc2258d0a73b

	/// Custo total de frete por pedido com filtro de data de emissão e filial.
	measure 'Custo Total Frete' =
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR TemFiltroFilial = ISCROSSFILTERED(protheus_filiais[Filial])
			VAR ResultadoBase =
			    SUMX(
			        VALUES(protheus_itensPedidosVendas[numero_pedido]),
			        VAR PedidoSelecionado = protheus_itensPedidosVendas[numero_pedido]
			        RETURN
			            COALESCE(
			                CALCULATE(
			                    MAX(protheus_pedidosVendas[Frete Valor]),
			                    TREATAS({ PedidoSelecionado }, protheus_pedidosVendas[numero])
			                ),
			                0
			            )
			    )
			VAR Resultado =
			    SWITCH(
			        TRUE(),
			        TemFiltroData && TemFiltroFilial,
			            CALCULATE(
			                ResultadoBase,
			                KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_emissao])),
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial])),
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_pedidosVendas[filial]))
			            ),
			        TemFiltroData,
			            CALCULATE(
			                ResultadoBase,
			                KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_emissao]))
			            ),
			        TemFiltroFilial,
			            CALCULATE(
			                ResultadoBase,
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial])),
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_pedidosVendas[filial]))
			            ),
			        ResultadoBase
			    )
			RETURN
			COALESCE(Resultado, 0)
		formatString: R$ #,##0.00
		displayFolder: Atacado
		lineageTag: f0587a39-dad2-4998-aecf-701e3524db26

	/// Clientes ativos considerando última compra até a data de referência, com data sem componente de hora e retorno 0 quando não houver referência.
	measure 'Clientes Ativos' =
			VAR DataReferencia =
			    COALESCE(
			        MAX(calendario[Date]),
			        CALCULATE(
			            MAXX(
			                protheus_itensPedidosVendas,
			                DATEVALUE(protheus_itensPedidosVendas[data_emissao])
			            ),
			            REMOVEFILTERS(calendario)
			        )
			    )
			VAR DataCorte = DataReferencia - 60
			VAR ClientesComUltimaCompra =
			    ADDCOLUMNS(
			        CALCULATETABLE(
			            VALUES(protheus_itensPedidosVendas[cod_cliente]),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			        ),
			        "@UltimaCompra",
			            CALCULATE(
			                MAXX(
			                    FILTER(
			                        protheus_itensPedidosVendas,
			                        DATEVALUE(protheus_itensPedidosVendas[data_emissao]) <= DataReferencia
			                    ),
			                    DATEVALUE(protheus_itensPedidosVendas[data_emissao])
			                ),
			                REMOVEFILTERS(calendario),
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			            )
			    )
			VAR Resultado =
			    COUNTROWS(
			        FILTER(
			            ClientesComUltimaCompra,
			            NOT(ISBLANK([@UltimaCompra]))
			                && [@UltimaCompra] >= DataCorte
			                && [@UltimaCompra] <= DataReferencia
			        )
			    )
			RETURN
			IF(ISBLANK(DataReferencia), 0, COALESCE(Resultado, 0))
		formatString: #,##0
		displayFolder: Atacado
		lineageTag: e64bd25e-5032-412d-867d-0688142fa6ac

	/// Clientes inativos considerando última compra até a data de referência, com data sem componente de hora e retorno 0 quando não houver referência.
	measure 'Clientes Inativos' =
			VAR DataReferencia =
			    COALESCE(
			        MAX(calendario[Date]),
			        CALCULATE(
			            MAXX(
			                protheus_itensPedidosVendas,
			                DATEVALUE(protheus_itensPedidosVendas[data_emissao])
			            ),
			            REMOVEFILTERS(calendario)
			        )
			    )
			VAR DataCorte = DataReferencia - 60
			VAR ClientesComUltimaCompra =
			    ADDCOLUMNS(
			        CALCULATETABLE(
			            VALUES(protheus_itensPedidosVendas[cod_cliente]),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			        ),
			        "@UltimaCompra",
			            CALCULATE(
			                MAXX(
			                    FILTER(
			                        protheus_itensPedidosVendas,
			                        DATEVALUE(protheus_itensPedidosVendas[data_emissao]) <= DataReferencia
			                    ),
			                    DATEVALUE(protheus_itensPedidosVendas[data_emissao])
			                ),
			                REMOVEFILTERS(calendario),
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			            )
			    )
			VAR Resultado =
			    COUNTROWS(
			        FILTER(
			            ClientesComUltimaCompra,
			            NOT(ISBLANK([@UltimaCompra]))
			                && [@UltimaCompra] < DataCorte
			        )
			    )
			RETURN
			IF(ISBLANK(DataReferencia), 0, COALESCE(Resultado, 0))
		formatString: #,##0
		displayFolder: Atacado
		lineageTag: a801e88b-ef68-4374-aeaa-7cdf1d0a3cc5

	measure 'Faturamento Base Auditoria' =
			
			CALCULATE(
			    SUM(protheus_itensPedidosVendas[preco_total]),
			    NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento]))
			)
		displayFolder: Atacado
		lineageTag: 4db6e9e6-6fb6-4be1-b091-bf68667defad

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Diferença Auditoria' =
			
			[Faturamento Atacado] - [Faturamento Base Auditoria]
		displayFolder: Atacado
