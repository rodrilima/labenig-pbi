	/// Situação do pedido baseada na regra: se houver nota fiscal nos itens do pedido, então Faturado; caso contrário, Em Aberto. Respeita filtros de data_faturamento e filial.
	measure 'ATC Tabela Pedidos - Situação' =
			VAR PedidoSelecionado = SELECTEDVALUE(protheus_itensPedidosVendas[numero_pedido])
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR TemFiltroFilial = ISCROSSFILTERED(protheus_filiais[Filial])
			VAR QtdItensComNota =
			    SWITCH(
			        TRUE(),
			        TemFiltroData && TemFiltroFilial,
			            CALCULATE(
			                COUNTROWS(protheus_itensPedidosVendas),
			                NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			                protheus_itensPedidosVendas[nota_fiscal] <> "",
			                KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento])),
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			            ),
			        TemFiltroData,
			            CALCULATE(
			                COUNTROWS(protheus_itensPedidosVendas),
			                NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			                protheus_itensPedidosVendas[nota_fiscal] <> "",
			                KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento]))
			            ),
			        TemFiltroFilial,
			            CALCULATE(
			                COUNTROWS(protheus_itensPedidosVendas),
			                NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			                protheus_itensPedidosVendas[nota_fiscal] <> "",
			                KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			            ),
			        CALCULATE(
			            COUNTROWS(protheus_itensPedidosVendas),
			            NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			            protheus_itensPedidosVendas[nota_fiscal] <> ""
			        )
			    )
			RETURN
			IF(
			    ISBLANK(PedidoSelecionado),
			    BLANK(),
			    IF(QtdItensComNota > 0, "Faturado", "Em Aberto")
			)
		displayFolder: Atacado\Tabela Pedidos
		lineageTag: f0de8811-cf3f-44fd-85c2-7b631200cf7c

	/// Valor bruto dos itens com suporte a filtros de mês/ano pela data de faturamento e por filial.
	measure 'ATC Tabela Pedidos - Valor Bruto' =
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR TemFiltroFilial = ISCROSSFILTERED(protheus_filiais[Filial])
			VAR ResultadoBase = SUM(protheus_itensPedidosVendas[preco_total])
			RETURN
			SWITCH(
			    TRUE(),
			    TemFiltroData && TemFiltroFilial,
			        CALCULATE(
			            SUM(protheus_itensPedidosVendas[preco_total]),
			            KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento])),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			        ),
			    TemFiltroData,
			        CALCULATE(
			            SUM(protheus_itensPedidosVendas[preco_total]),
			            KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento]))
			        ),
			    TemFiltroFilial,
			        CALCULATE(
			            SUM(protheus_itensPedidosVendas[preco_total]),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial]))
			        ),
			    ResultadoBase
			)
		formatString: R$ #,##0.00
		displayFolder: Atacado\Tabela Pedidos
		lineageTag: e48fb661-f00c-45b3-8b1d-0719df00c0e6

	/// Desconto por pedido filtrável por data de faturamento e filial, sem duplicidade por quantidade de itens.
	measure 'ATC Tabela Pedidos - Desconto' =
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR TemFiltroFilial = ISCROSSFILTERED(protheus_filiais[Filial])
			VAR ResultadoBase =
			    SUMX(
			        VALUES(protheus_itensPedidosVendas[numero_pedido]),
			        VAR PedidoSelecionado = protheus_itensPedidosVendas[numero_pedido]
			        RETURN
			            COALESCE(
			                CALCULATE(
			                    MAX(protheus_pedidosVendas[Desconto Valor]),
			                    TREATAS({ PedidoSelecionado }, protheus_pedidosVendas[numero])
			                ),
			                0
			            )
			    )
			RETURN
			SWITCH(
			    TRUE(),
			    TemFiltroData && TemFiltroFilial,
			        CALCULATE(
			            ResultadoBase,
			            KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento])),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial])),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_pedidosVendas[filial]))
			        ),
			    TemFiltroData,
			        CALCULATE(
			            ResultadoBase,
			            KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento]))
			        ),
			    TemFiltroFilial,
			        CALCULATE(
			            ResultadoBase,
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial])),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_pedidosVendas[filial]))
			        ),
			    ResultadoBase
			)
		formatString: R$ #,##0.00
		displayFolder: Atacado\Tabela Pedidos
		lineageTag: c9c2cfe8-a50d-43fb-a474-a7d33c60aba2

	/// Frete por pedido filtrável por data de faturamento e filial, sem duplicidade por quantidade de itens.
	measure 'ATC Tabela Pedidos - Frete' =
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR TemFiltroFilial = ISCROSSFILTERED(protheus_filiais[Filial])
			VAR ResultadoBase =
			    SUMX(
			        VALUES(protheus_itensPedidosVendas[numero_pedido]),
			        VAR PedidoSelecionado = protheus_itensPedidosVendas[numero_pedido]
			        RETURN
			            COALESCE(
			                CALCULATE(
			                    MAX(protheus_pedidosVendas[Frete Valor]),
			                    TREATAS({ PedidoSelecionado }, protheus_pedidosVendas[numero])
			                ),
			                0
			            )
			    )
			RETURN
			SWITCH(
			    TRUE(),
			    TemFiltroData && TemFiltroFilial,
			        CALCULATE(
			            ResultadoBase,
			            KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento])),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial])),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_pedidosVendas[filial]))
			        ),
			    TemFiltroData,
			        CALCULATE(
			            ResultadoBase,
			            KEEPFILTERS(TREATAS(VALUES(calendario[Date]), protheus_itensPedidosVendas[data_faturamento]))
			        ),
			    TemFiltroFilial,
			        CALCULATE(
			            ResultadoBase,
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_itensPedidosVendas[filial])),
			            KEEPFILTERS(TREATAS(VALUES(protheus_filiais[Filial]), protheus_pedidosVendas[filial]))
			        ),
			    ResultadoBase
			)
		formatString: R$ #,##0.00
		displayFolder: Atacado\Tabela Pedidos
		lineageTag: 0767bee7-903c-4680-8393-e5d604ef12e2

	/// Classifica o pedido como Aberto ou Faturado combinando evidências do cabeçalho (nota) e dos itens (data_faturamento).
	measure 'ATC Situação Pedido (Aberto/Faturado)' =
			VAR PedidoSelecionado =
			    COALESCE(
			        SELECTEDVALUE(protheus_itensPedidosVendas[numero_pedido]),
			        SELECTEDVALUE(protheus_pedidosVendas[numero])
			    )
			VAR QtdItensFaturados =
			    CALCULATE(
			        COUNTROWS(protheus_itensPedidosVendas),
			        TREATAS({ PedidoSelecionado }, protheus_itensPedidosVendas[numero_pedido]),
			        NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento]))
			    )
			VAR QtdPedidosComNota =
			    CALCULATE(
			        COUNTROWS(protheus_pedidosVendas),
			        TREATAS({ PedidoSelecionado }, protheus_pedidosVendas[numero]),
			        NOT(ISBLANK(protheus_pedidosVendas[nota])),
			        TRIM(protheus_pedidosVendas[nota]) <> ""
			    )
			RETURN
			IF(
			    ISBLANK(PedidoSelecionado),
			    BLANK(),
			    IF(QtdItensFaturados > 0 || QtdPedidosComNota > 0, "Faturado", "Aberto")
			)
		displayFolder: Atacado\Tabela Pedidos
		lineageTag: b1c572bc-72bc-4984-80f2-c46accafd455

	/// Valor líquido calculado para a tabela de pedidos: Bruto - Desconto + Frete.
	measure 'ATC Tabela Pedidos - Valor Líquido' = [ATC Tabela Pedidos - Valor Bruto] - [ATC Tabela Pedidos - Desconto] + [ATC Tabela Pedidos - Frete]
		formatString: R$ #,##0.00
		displayFolder: Atacado\Tabela Pedidos
		lineageTag: 495b1aeb-740b-4134-a9fe-b256551fb54b

