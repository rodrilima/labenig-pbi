	/// Percentual de inadimplência calculado sobre a posição do período selecionado no calendário
	measure 'CR Inadimplência % (Posição)' =
			
			VAR total_mes =
			    [CR Total em Aberto (Posição)]
			RETURN
			IF(
			    total_mes > 0,
			    DIVIDE(
			        [CR Valor Inadimplente (Posição)],
