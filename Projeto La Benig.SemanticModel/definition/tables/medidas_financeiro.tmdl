	/// Quantidade de títulos vencidos e não pagos
	measure 'CP Qtd Títulos em Atraso' =
			CALCULATE(
			    COUNTROWS(protheus_contasPagar),
			    protheus_contasPagar[saldo] > 0,
			    protheus_contasPagar[data_vencimento] < TODAY()
