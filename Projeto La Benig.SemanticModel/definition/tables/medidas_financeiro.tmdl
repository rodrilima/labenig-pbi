	/// Saldo de títulos vencidos e ainda não pagos
	measure 'CP Valor em Atraso' =
			CALCULATE(
			    SUM(protheus_contasPagar[saldo]),
			    protheus_contasPagar[saldo] > 0,
			    protheus_contasPagar[data_vencimento] < TODAY()
			)
