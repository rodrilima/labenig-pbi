	measure 'Saldo Inicial Periodo' =
			VAR DataInicial =
			    MIN('calendario'[Date])
			
			RETURN
			CALCULATE(
			    [Fluxo Liquido Projetado],
			    FILTER(
			        ALL('Calendario'),
			        'Calendario'[Date] < DataInicial
			    )
			)
