	/// UF padronizada para análises geográficas de Vendas Atacado.
	column estado_uf =
			VAR UF = UPPER(TRIM(protheus_contatos[estado]))
			RETURN IF(LEN(UF) = 2, UF, BLANK())
		dataType: string
		lineageTag: 499fece7-78c6-4403-a01b-c6d18d3d8f87
		dataCategory: StateOrProvince
		summarizeBy: none

