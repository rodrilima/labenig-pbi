table protheus_pedidosVendas
	lineageTag: 5d4721c0-19c1-450f-908c-ec1691833e18

	/// Faturamento total atacado (PJ) na filial 010102, considerando apenas notas faturadas e filtrando por data_faturamento quando houver seleção no calendário.
	measure 'ATC Faturamento Total' =
			VAR TemFiltroData = ISCROSSFILTERED(calendario[Date])
			VAR ClientesPJNoContexto =
			    CALCULATETABLE(
			        VALUES(protheus_contatos[codigo]),
			        KEEPFILTERS(protheus_contatos[tipo_pessoa] = "J")
			    )
			VAR ResultadoSemData =
			    CALCULATE(
			        SUM(protheus_itensPedidosVendas[preco_total]),
			        protheus_itensPedidosVendas[filial] = "010102",
			        NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			        TRIM(protheus_itensPedidosVendas[nota_fiscal]) <> "",
			        NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento])),
			        TREATAS(ClientesPJNoContexto, protheus_itensPedidosVendas[cod_cliente])
			    )
			VAR ResultadoComData =
			    CALCULATE(
			        SUM(protheus_itensPedidosVendas[preco_total]),
			        protheus_itensPedidosVendas[filial] = "010102",
			        NOT(ISBLANK(protheus_itensPedidosVendas[nota_fiscal])),
			        TRIM(protheus_itensPedidosVendas[nota_fiscal]) <> "",
			        NOT(ISBLANK(protheus_itensPedidosVendas[data_faturamento])),
			        KEEPFILTERS(
			            FILTER(
			                protheus_itensPedidosVendas,
			                DATEVALUE(protheus_itensPedidosVendas[data_faturamento]) IN VALUES(calendario[Date])
			            )
			        ),
			        TREATAS(ClientesPJNoContexto, protheus_itensPedidosVendas[cod_cliente])
			    )
			RETURN
			COALESCE(IF(TemFiltroData, ResultadoComData, ResultadoSemData), 0)
		formatString: R$ #,##0.00
		displayFolder: Atacado Mapa Geografico
		lineageTag: 30e196e1-62f1-456e-95b9-876dcfa4dc86

	/// Quantidade de pedidos atacado (filial 010102) de clientes PJ.
	measure 'ATC Pedidos' =
			VAR ClientesPJNoContexto =
			    CALCULATETABLE(
			        VALUES(protheus_contatos[codigo]),
			        KEEPFILTERS(protheus_contatos[tipo_pessoa] = "J")
			    )
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT(protheus_pedidosVendas[numero]),
			        protheus_pedidosVendas[filial] = "010102",
			        TREATAS(ClientesPJNoContexto, protheus_pedidosVendas[cod_cliente])
			    )
		formatString: 0
		displayFolder: Atacado Mapa Geografico
		lineageTag: c1e7bdef-8b47-4d27-aeb2-d8813a6246a5

	/// Clientes PJ com compra atacado no estado em contexto.
	measure 'ATC Clientes por Estado' =
			VAR ClientesPJNoContexto =
			    CALCULATETABLE(
			        VALUES(protheus_contatos[codigo]),
			        KEEPFILTERS(protheus_contatos[tipo_pessoa] = "J")
			    )
			VAR ClientesComPedidoAtacado =
			    CALCULATETABLE(
			        VALUES(protheus_pedidosVendas[cod_cliente]),
			        protheus_pedidosVendas[filial] = "010102",
			        TREATAS(ClientesPJNoContexto, protheus_pedidosVendas[cod_cliente])
			    )
			RETURN
			    COUNTROWS(INTERSECT(ClientesPJNoContexto, ClientesComPedidoAtacado))
		formatString: 0
		displayFolder: Atacado Mapa Geografico
		lineageTag: 5f5b0baf-9ca0-47a9-b9a9-90a167f1f9bd

	/// Total de UFs com faturamento de atacado no contexto atual.
	measure 'ATC Estados Atendidos' =
			COUNTROWS(
			    FILTER(
			        VALUES(protheus_contatos[estado_uf]),
			        CALCULATE([ATC Faturamento Total]) > 0
			    )
			)
		formatString: 0
		displayFolder: Atacado Mapa Geografico
		lineageTag: e60056b3-1dbd-41e1-a785-de33624995ce

	/// Participação percentual da UF no faturamento atacado. Denominador usa ALLSELECTED para respeitar slicers de estado mas remover o contexto de linha da tabela.
	measure 'ATC Participacao Estado %' =
			VAR TodosClientesPJ =
			    CALCULATETABLE(
			        VALUES(protheus_contatos[codigo]),
			        ALLSELECTED(protheus_contatos[estado_uf]),
			        KEEPFILTERS(protheus_contatos[tipo_pessoa] = "J")
			    )
			VAR TotalGlobal =
			    CALCULATE(
			        SUM(protheus_itensPedidosVendas[preco_total]),
			        protheus_itensPedidosVendas[filial] = "010102",
			        TREATAS(TodosClientesPJ, protheus_itensPedidosVendas[cod_cliente])
			    )
			RETURN
			    DIVIDE([ATC Faturamento Total], TotalGlobal)
		formatString: 0.00%
		displayFolder: Atacado Mapa Geografico
		lineageTag: 7f5a2214-1cac-4488-ba64-b2522f1bafb5

	/// Ticket médio de atacado (faturamento/pedidos).
	measure 'ATC Ticket Medio' = DIVIDE([ATC Faturamento Total], [ATC Pedidos])
		formatString: R$ #,##0.00
		displayFolder: Atacado Mapa Geografico
		lineageTag: b80228ea-c965-46eb-857e-721373d08922

	/// Pedidos atacado ainda sem nota (abertos).
	measure 'ATC Pedidos em Aberto' =
			VAR ClientesPJNoContexto =
			    CALCULATETABLE(
			        VALUES(protheus_contatos[codigo]),
			        KEEPFILTERS(protheus_contatos[tipo_pessoa] = "J")
			    )
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT(protheus_pedidosVendas[numero]),
			        protheus_pedidosVendas[filial] = "010102",
			        FILTER(
			            protheus_pedidosVendas,
			            ISBLANK(protheus_pedidosVendas[nota]) || TRIM(protheus_pedidosVendas[nota]) = ""
			        ),
			        TREATAS(ClientesPJNoContexto, protheus_pedidosVendas[cod_cliente])
			    )
		formatString: 0
		displayFolder: Atacado Mapa Geografico
		lineageTag: 78face25-4442-4bdc-b258-290e481846d4

	/// Clientes PJ com compra atacado nos últimos 60 dias.
	measure 'ATC Clientes Ativos 60d' =
			VAR ClientesPJNoContexto =
			    CALCULATETABLE(
			        VALUES(protheus_contatos[codigo]),
			        KEEPFILTERS(protheus_contatos[tipo_pessoa] = "J")
			    )
			VAR BaseClientes =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            VALUES(protheus_pedidosVendas[cod_cliente]),
			            "UltimaCompra", CALCULATE(MAX(protheus_pedidosVendas[data_emissao]))
			        ),
			        protheus_pedidosVendas[filial] = "010102",
			        TREATAS(ClientesPJNoContexto, protheus_pedidosVendas[cod_cliente])
			    )
			RETURN
			    COUNTROWS(
			        FILTER(BaseClientes, NOT ISBLANK([UltimaCompra]) && [UltimaCompra] >= TODAY() - 60)
			    )
		formatString: 0
		displayFolder: Atacado Mapa Geografico
		lineageTag: 05c8b02e-9c74-4b8e-8ff0-3ffff74d6c19

	/// Clientes PJ com última compra atacado há mais de 60 dias.
	measure 'ATC Clientes Inativos 60d' =
			VAR ClientesPJNoContexto =
			    CALCULATETABLE(
			        VALUES(protheus_contatos[codigo]),
			        KEEPFILTERS(protheus_contatos[tipo_pessoa] = "J")
			    )
			VAR BaseClientes =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            VALUES(protheus_pedidosVendas[cod_cliente]),
			            "UltimaCompra", CALCULATE(MAX(protheus_pedidosVendas[data_emissao]))
			        ),
			        protheus_pedidosVendas[filial] = "010102",
			        TREATAS(ClientesPJNoContexto, protheus_pedidosVendas[cod_cliente])
			    )
			RETURN
			    COUNTROWS(
			        FILTER(BaseClientes, NOT ISBLANK([UltimaCompra]) && [UltimaCompra] < TODAY() - 60)
			    )
		formatString: 0
		displayFolder: Atacado Mapa Geografico
		lineageTag: fe1b2b9f-554b-4313-a224-daa51a28c057

	measure 'Itens Sem Pedido' =
			
			CALCULATE(
			    SUM(protheus_itensPedidosVendas[preco_total]),
			    NOT(
			        protheus_itensPedidosVendas[numero_pedido]
			            IN VALUES(protheus_pedidosVendas[numero])
			    )
			)
		lineageTag: 71cfbf4d-f898-4b98-ba76-01013c43e57d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Repeticoes =
			
			CALCULATE(
			    COUNT(protheus_pedidosVendas[numero]),
			    ALLEXCEPT(protheus_pedidosVendas, protheus_pedidosVendas[numero])
			)
		formatString: 0
		lineageTag: 9273dd1a-05d6-4ab3-b539-1eac1b8b0a3a

