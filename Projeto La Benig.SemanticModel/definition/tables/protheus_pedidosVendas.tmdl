	column Classificacao_Venda =
			IF(
			    protheus_pedidosVendas[filial] = "010102",
			    "ATACADO",
			    "VAREJO"
			)
		dataType: string
		lineageTag: 436235eb-3b6e-44ae-9aaa-7b499c7fa8b4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column status_pedido = IF(protheus_pedidosVendas[nota] = "" || ISBLANK(protheus_pedidosVendas[nota]), "Em aberto", "Faturado")
		dataType: string
		lineageTag: fe26bec9-38a1-4168-839c-a2e81dd77221
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Desconto convertido para numérico para exibição e agregação em tabela de pedidos.
	column 'Desconto Valor' =
			VAR Txt0 = TRIM(SUBSTITUTE(SUBSTITUTE(protheus_pedidosVendas[desconto], "R$", ""), " ", ""))
			VAR Txt1 = IF(CONTAINSSTRING(Txt0, ","), SUBSTITUTE(SUBSTITUTE(Txt0, ".", ""), ",", "."), Txt0)
			RETURN IF(Txt1 = "" || Txt1 = "-", BLANK(), IFERROR(VALUE(Txt1), BLANK()))
		dataType: double
		formatString: R$ #,##0.00
		lineageTag: d06494ad-d83d-4e74-aabe-1c1dfc0549a5
		summarizeBy: sum

	/// Frete convertido para numérico para exibição e agregação em tabela de pedidos.
	column 'Frete Valor' =
			VAR Txt0 = TRIM(SUBSTITUTE(SUBSTITUTE(protheus_pedidosVendas[frete], "R$", ""), " ", ""))
			VAR Txt1 = IF(CONTAINSSTRING(Txt0, ","), SUBSTITUTE(SUBSTITUTE(Txt0, ".", ""), ",", "."), Txt0)
			RETURN IF(Txt1 = "" || Txt1 = "-", BLANK(), IFERROR(VALUE(Txt1), BLANK()))
		dataType: double
		formatString: R$ #,##0.00
		lineageTag: 0f4fdb11-0b0d-4b6e-a819-4810eb879bb6
		summarizeBy: sum

	column AAARepeticoes =
			
			CALCULATE(
			    COUNT(protheus_pedidosVendas[numero]),
			    ALLEXCEPT(protheus_pedidosVendas, protheus_pedidosVendas[numero])
			)
		formatString: 0
		lineageTag: d2f6c20d-2646-4a56-8159-3d0f03f1117b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

